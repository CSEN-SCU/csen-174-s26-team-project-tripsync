# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional but recommended for reliable Microsoft voice TTS.
# Get these from Azure Speech service:
# https://portal.azure.com -> Speech resource -> Keys and Endpoint
AZURE_TTS_KEY=your_azure_speech_key_here
AZURE_TTS_REGION=your_azure_region_here
AZURE_TTS_VOICE=en-US-JennyNeural
