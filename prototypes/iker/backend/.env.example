# Orbit Together — backend env
# Copy to .env and fill in. Never commit the real .env.

# Required for AI-generated POIs + group narration.
# Free key: https://console.groq.com/keys
GROQ_API_KEY=

# Optional overrides
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Optional: set to 1 to fall back to seed POIs even when GROQ_API_KEY is set
# (useful for a stable gallery-walk demo).
ORBIT_USE_SEED_ONLY=0
